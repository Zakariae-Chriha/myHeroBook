# ============================================================
# THE HERO KIDS STORYLAB — ENVIRONMENT VARIABLES
# Copy this file to .env and fill in your actual values
# NEVER commit .env to version control
# ============================================================

# ─── APP ────────────────────────────────────────────────────
NODE_ENV=development
PORT=5000
CLIENT_URL=http://localhost:3000
API_URL=http://localhost:5000

# ─── DATABASE ───────────────────────────────────────────────
# MongoDB Atlas connection string
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/hero-kids-storylab?retryWrites=true&w=majority

# ─── JWT ────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET=your_access_token_secret_min_64_chars
JWT_REFRESH_SECRET=your_refresh_token_secret_min_64_chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# ─── REDIS ──────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# ─── CLOUDINARY ─────────────────────────────────────────────
# https://cloudinary.com/console
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
CLOUDINARY_FOLDER_PHOTOS=hero-kids/child-photos
CLOUDINARY_FOLDER_ILLUSTRATIONS=hero-kids/illustrations

# ─── AWS S3 ─────────────────────────────────────────────────
# For PDF storage and audio files
AWS_ACCESS_KEY_ID=your_aws_access_key_id
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key
AWS_REGION=eu-west-1
AWS_S3_BUCKET_PDFS=hero-kids-pdfs
AWS_S3_BUCKET_AUDIO=hero-kids-audio
AWS_S3_SIGNED_URL_EXPIRES=604800

# ─── ANTHROPIC (CLAUDE AI) ──────────────────────────────────
# https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-your_anthropic_api_key
CLAUDE_MODEL=claude-sonnet-4-20250514

# ─── REPLICATE ──────────────────────────────────────────────
# https://replicate.com/account/api-tokens
REPLICATE_API_TOKEN=r8_your_replicate_api_token
REPLICATE_SDXL_MODEL=stability-ai/sdxl:39ed52f2319f9c5a9f4e4b9f668a7bbbf2d2ff8e4a895e1c1e64e46e9b0c3e7f

# ─── ELEVENLABS ─────────────────────────────────────────────
# https://elevenlabs.io/
ELEVENLABS_API_KEY=your_elevenlabs_api_key
ELEVENLABS_MODEL_ID=eleven_multilingual_v2

# ─── STRIPE ─────────────────────────────────────────────────
# https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key
STRIPE_WEBHOOK_SECRET=whsec_your_stripe_webhook_secret

# Stripe Price IDs — create these in Stripe Dashboard
STRIPE_PRICE_DIGITAL=price_digital_999
STRIPE_PRICE_PRINTED=price_printed_3499
STRIPE_PRICE_VOICE=price_voice_5499
STRIPE_PRICE_BUNDLE=price_bundle_14900
STRIPE_PRICE_MONTHLY=price_monthly_799
STRIPE_PRICE_YEARLY=price_yearly_5999
STRIPE_PRICE_ADDON_RUSH=price_addon_rush_999
STRIPE_PRICE_ADDON_EXTRA=price_addon_extra_1999
STRIPE_PRICE_ADDON_GIFT=price_addon_gift_499
STRIPE_PRICE_ADDON_VOICE=price_addon_voice_1499

# ─── GELATO (PRINT-ON-DEMAND) ───────────────────────────────
# https://dashboard.gelato.com/
GELATO_API_KEY=your_gelato_api_key
GELATO_API_URL=https://api.gelato.com
GELATO_WEBHOOK_SECRET=your_gelato_webhook_secret

# ─── SENDGRID ───────────────────────────────────────────────
# https://app.sendgrid.com/settings/api_keys
SENDGRID_API_KEY=SG.your_sendgrid_api_key
EMAIL_FROM=noreply@herokidsstorylab.com
EMAIL_FROM_NAME=The Hero Kids StoryLab

# ─── BCRYPT ─────────────────────────────────────────────────
BCRYPT_ROUNDS=12

# ─── RATE LIMITING ──────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
AI_RATE_LIMIT_WINDOW_MS=3600000
AI_RATE_LIMIT_MAX_REQUESTS=5

# ─── BULL QUEUE ─────────────────────────────────────────────
QUEUE_CONCURRENCY_IMAGES=4
QUEUE_CONCURRENCY_VOICE=2
QUEUE_CONCURRENCY_PDF=1

# ─── CORS ───────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000,https://herokidsstorylab.com

# ─── FRONTEND (Vite environment variables) ──────────────────
# These are prefixed with VITE_ to be accessible in the client
VITE_API_URL=http://localhost:5000/api
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key
VITE_APP_NAME=The Hero Kids StoryLab
